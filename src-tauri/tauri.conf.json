{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hihii",
  "version": "1.0.1",
  "identifier": "com.hihii.launcher",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hihii",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}